# ── Gemini ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=GEMINIAPIKEY

# Optional: override the default model (gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# ── Google Places API ────────────────────────────────────────────────────────
# Same key used by the React Native frontend (from .env in project root)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=GOOGLE_PLACES_API_KEY

# ── Supabase (for seed_landmarks.py) ─────────────────────────────────────────
# Service role key bypasses RLS — never expose to the frontend!
SUPABASE_URL=https://abc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY

# ── File Search ──────────────────────────────────────────────────────────────
# Comma-separated File Search store resource names (created via the API or UI)
# FILE_SEARCH_STORE_NAMES=fileSearchStores/my-store-1,fileSearchStores/my-store-2

# ── Security ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable auth (development only)
BACKEND_API_KEY=

# ── API server ───────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true
