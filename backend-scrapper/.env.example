# ── PredictHQ credentials ─────────────────────────────────────────────────────
# Generate at: https://control.predicthq.com/clients
PREDICTHQ_API_KEY=your_predicthq_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Service role key bypasses RLS — NEVER expose to frontend or commit to git!
SUPABASE_URL=https://dwtjtliumpdctqexktzg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Scrape range (ISO 8601 dates) ─────────────────────────────────────────────
# Defaults shown; override to narrow the window
SCRAPE_START_DATE=2025-01-01
SCRAPE_END_DATE=2027-12-31

# ── Countries: comma-separated ISO alpha-2 codes, or ALL ─────────────────────
# BN,KH,ID,LA,MY,MM,PH,SG,TH,TL,VN   — or —   ALL
SCRAPE_COUNTRIES=ALL

# ── Categories: comma-separated PredictHQ categories, or ALL ─────────────────
# concerts,festivals,expos,sports,conferences,community,performing-arts,…
SCRAPE_CATEGORIES=ALL

# ── Tuning ────────────────────────────────────────────────────────────────────
# Max events per API request (1–200)
PAGE_SIZE=200

# Minimum PredictHQ rank to keep (0 = keep everything)
MIN_RANK=0

# How many rows to upsert to Supabase per batch
UPSERT_BATCH_SIZE=500

# Date window size in days (prevents hitting the 10 k offset limit)
DATE_CHUNK_DAYS=90

# HTTP retry settings
MAX_RETRIES=5
RETRY_WAIT_SECONDS=2.0
